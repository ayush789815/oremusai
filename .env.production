# Production build — calls the hosted backend directly (axios honours this).
NEXT_PUBLIC_API_URL=https://api.oremusai.vensframe.com/api

# Server-only proxy target for next.config.js rewrites (if /api is used relatively).
API_PROXY_TARGET=https://api.oremusai.vensframe.com

# ── Zoho OAuth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ZOHO_CLIENT_ID=1000.HGRX7XEKT4RKE1JO9WKIP65AUANDAJ
NEXT_PUBLIC_ZOHO_REDIRECT_URI=https://oremusai.vensframe.com/auth/zoho/callback
NEXT_PUBLIC_ZOHO_API_BASE=https://www.zohoapis.in/books/v3
NEXT_PUBLIC_ZOHO_ACCOUNTS_URL=https://accounts.zoho.in/oauth/v2
NEXT_PUBLIC_ZOHO_AUTH_URL=https://accounts.zoho.in/oauth/v2/auth
NEXT_PUBLIC_ZOHO_TOKEN_URL=https://accounts.zoho.in/oauth/v2/token
NEXT_PUBLIC_ZOHO_ORG_ID=60069197945

# ── QuickBooks Online ─────────────────────────────────────────────────────────
NEXT_PUBLIC_QBO_ENV=sandbox
